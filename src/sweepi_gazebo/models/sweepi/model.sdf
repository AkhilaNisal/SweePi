<?xml version="1.0"?>
<!--
  SweePi Gazebo SDF model.

  All Gazebo-specific simulation details (sensors, plugins, physics) live here.
  The matching URDF (sweepi_description) provides the pure ROS robot description
  (links, joints, meshes) used by ROS tools such as robot_state_publisher and Rviz.

  Coordinate reference (all poses relative to model / base_footprint frame):
    body_radius        = 0.200 m
    body_height        = 0.100 m
    ground_clearance   = 0.020 m
    drive_wheel_radius = 0.025 m
    drive_wheel_width  = 0.020 m
    wheel_span         = 0.300 m   (centre-to-centre)
    caster_offset_x    = 0.160 m
    caster_radius      = 0.010 m   (= ground_clearance / 2)

  Derived absolute z positions (model frame):
    base_link z  = ground_clearance + body_height/2 = 0.070 m
    wheel z      = drive_wheel_radius              = 0.025 m
    caster z     = caster_radius                   = 0.010 m
    base_scan z  = base_link z + 0.150             = 0.220 m
-->
<sdf version="1.9">
  <model name="sweepi">
    <static>false</static>

    <!-- ================================================================
         LINKS
         ================================================================ -->

    <!-- Base footprint (root / ground-projection frame) -->
    <link name="base_footprint">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-06</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-06</iyy><iyz>0</iyz>
          <izz>1e-06</izz>
        </inertia>
      </inertial>
    </link>

    <!-- Robot body (cylinder r=0.2, h=0.1, m=3.0) -->
    <link name="base_link">
      <pose>0 0 0.07 0 0 0</pose>
      <inertial>
        <mass>3.0</mass>
        <!-- ixx = iyy = m*(3r²+h²)/12  r=0.2 h=0.1  → 3*(0.12+0.01)/12 = 0.0325 -->
        <!-- izz = m*r²/2               r=0.2         → 3*0.04/2         = 0.0600 -->
        <inertia>
          <ixx>0.0325</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0325</iyy><iyz>0</iyz>
          <izz>0.0600</izz>
        </inertia>
      </inertial>
      <visual name="base_link_visual">
        <geometry>
          <cylinder>
            <radius>0.2</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.88 0.88 0.85 1</diffuse>
        </material>
      </visual>
      <collision name="base_link_collision">
        <geometry>
          <cylinder>
            <radius>0.2</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <!-- Left drive wheel (cylinder r=0.025, l=0.020, m=0.15, axis=Y) -->
    <link name="left_wheel_link">
      <pose>0 0.15 0.025 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <!-- Wheel axis = Y.  Cylinder axis was Z; rotated pi/2 around X.
             ixx_new = ixx_old = m*(3r²+l²)/12 ≈ 2.84e-5
             iyy_new = izz_old = m*r²/2         ≈ 4.69e-5
             izz_new = iyy_old = m*(3r²+l²)/12 ≈ 2.84e-5 -->
        <inertia>
          <ixx>2.84e-05</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>4.69e-05</iyy><iyz>0</iyz>
          <izz>2.84e-05</izz>
        </inertia>
      </inertial>
      <visual name="left_wheel_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="left_wheel_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Right drive wheel -->
    <link name="right_wheel_link">
      <pose>0 -0.15 0.025 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>2.84e-05</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>4.69e-05</iyy><iyz>0</iyz>
          <izz>2.84e-05</izz>
        </inertia>
      </inertial>
      <visual name="right_wheel_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="right_wheel_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Front caster (sphere r=0.010, m=0.05, low friction) -->
    <link name="front_caster_link">
      <pose>0.16 0 0.01 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <!-- ixx = iyy = izz = 2*m*r²/5  r=0.01 → 2e-6 -->
        <inertia>
          <ixx>2.0e-06</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.0e-06</iyy><iyz>0</iyz>
          <izz>2.0e-06</izz>
        </inertia>
      </inertial>
      <visual name="front_caster_visual">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
        <material>
          <diffuse>0.9 0.48 0.13 1</diffuse>
        </material>
      </visual>
      <collision name="front_caster_collision">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.1</mu><mu2>0.1</mu2></ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Rear caster -->
    <link name="rear_caster_link">
      <pose>-0.16 0 0.01 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>2.0e-06</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.0e-06</iyy><iyz>0</iyz>
          <izz>2.0e-06</izz>
        </inertia>
      </inertial>
      <visual name="rear_caster_visual">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
        <material>
          <diffuse>0.9 0.48 0.13 1</diffuse>
        </material>
      </visual>
      <collision name="rear_caster_collision">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.1</mu><mu2>0.1</mu2></ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- LIDAR mount link (cylinder matching URDF base_scan geometry)
         Holds the gpu_lidar sensor — NOT defined in the URDF. -->
    <link name="base_scan">
      <pose>0 0 0.22 0 0 0</pose>
      <inertial>
        <mass>0.114</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="base_scan_visual">
        <geometry>
          <cylinder>
            <radius>0.0508</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="base_scan_collision">
        <geometry>
          <cylinder>
            <radius>0.0508</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>

      <!-- GPU LIDAR sensor
           720 samples · 360° · 10 Hz · 0.05–12.0 m range
           Publishes to /scan (bridged to ROS via ros_gz_bridge). -->
      <sensor name="scan" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>scan</topic>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>12.0</max>
            <resolution>0.005</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.001</stddev>
          </noise>
        </lidar>
        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>

    <!-- ================================================================
         JOINTS
         ================================================================ -->

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
    </joint>

    <!-- Revolute joints for drive wheels (axis = Y in model frame) -->
    <joint name="base_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.01</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="base_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.01</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="base_front_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_caster_link</child>
    </joint>

    <joint name="base_rear_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>rear_caster_link</child>
    </joint>

    <joint name="scan_joint" type="fixed">
      <parent>base_link</parent>
      <child>base_scan</child>
    </joint>

    <!-- ================================================================
         PLUGINS
         ================================================================ -->

    <!-- Differential Drive — wheel_radius 0.025 m, separation 0.3 m -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>base_left_wheel_joint</left_joint>
      <right_joint>base_right_wheel_joint</right_joint>
      <wheel_separation>0.300</wheel_separation>
      <wheel_radius>0.025</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/model/sweepi/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/model/sweepi/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <max_linear_acceleration>1.0</max_linear_acceleration>
    </plugin>

    <!-- Joint State Publisher — publishes wheel joint positions for ROS bridge -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>base_left_wheel_joint</joint_name>
      <joint_name>base_right_wheel_joint</joint_name>
    </plugin>

  </model>
</sdf>
