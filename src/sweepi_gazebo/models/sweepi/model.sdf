<?xml version="1.0"?>
<sdf version="1.9">
  <model name="sweepi">
    <pose>0 0 0 0 0 0</pose>

    <link name="base_footprint"/>

    <link name="base_link">
      <inertial>
        <mass>3.0</mass>
        <inertia>
          <ixx>0.0208</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0208</iyy>
          <iyz>0.0</iyz>
          <izz>0.0300</izz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <cylinder>
            <radius>0.200</radius>
            <length>0.100</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="base_visual">
        <geometry>
          <cylinder>
            <radius>0.200</radius>
            <length>0.100</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.88 0.88 0.85 1.0</ambient>
          <diffuse>0.88 0.88 0.85 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel_link">
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.00005</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00005</iyy>
          <iyz>0.0</iyz>
          <izz>0.00009</izz>
        </inertia>
      </inertial>

      <collision name="wheel_left_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="wheel_left_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel_link">
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.00005</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00005</iyy>
          <iyz>0.0</iyz>
          <izz>0.00009</izz>
        </inertia>
      </inertial>

      <collision name="wheel_right_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="wheel_right_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.020</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_caster_link">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0.0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <collision name="front_caster_collision">
        <geometry>
          <sphere>
            <radius>0.010</radius>
          </sphere>
        </geometry>
      </collision>

      <visual name="front_caster_visual">
        <geometry>
          <sphere>
            <radius>0.010</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.90 0.48 0.13 1.0</ambient>
          <diffuse>0.90 0.48 0.13 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_caster_link">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0.0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <collision name="rear_caster_collision">
        <geometry>
          <sphere>
            <radius>0.010</radius>
          </sphere>
        </geometry>
      </collision>

      <visual name="rear_caster_visual">
        <geometry>
          <sphere>
            <radius>0.010</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.90 0.48 0.13 1.0</ambient>
          <diffuse>0.90 0.48 0.13 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="lidar_link">
      <inertial>
        <mass>0.17</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0.0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>

      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.038</radius>
            <length>0.041</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.038</radius>
            <length>0.041</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.2 0.2 0.2 1.0</diffuse>
        </material>
      </visual>

      <sensor name="gpu_lidar" type="gpu_lidar">
        <topic>scan</topic>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>12.0</max>
            <resolution>0.015</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <link name="camera_link">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0.0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <collision name="camera_collision">
        <geometry>
          <box>
            <size>0.015 0.090 0.025</size>
          </box>
        </geometry>
      </collision>

      <visual name="camera_visual">
        <geometry>
          <box>
            <size>0.015 0.090 0.025</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.2 0.2 0.2 1.0</diffuse>
        </material>
      </visual>

      <sensor name="camera" type="camera">
        <topic>camera/image_raw</topic>
        <camera>
          <horizontal_fov>1.3962634</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>15</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <always_on>true</always_on>
        <update_rate>20</update_rate>
        <visualize>false</visualize>
      </sensor>
    </link>

    <link name="imu_link">
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.000001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.000001</iyy>
          <iyz>0.0</iyz>
          <izz>0.000001</izz>
        </inertia>
      </inertial>

      <sensor name="tb3_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>200</update_rate>
        <topic>imu</topic>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.017</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.017</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.017</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0.07 0 0 0</pose>
    </joint>

    <joint name="base_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <pose>0 0.15 -0.047 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <effort>20</effort>
          <velocity>2.0</velocity>
        </limit>
        <dynamics>
          <damping>0.01</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="base_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <pose>0 -0.15 -0.047 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <effort>20</effort>
          <velocity>2.0</velocity>
        </limit>
        <dynamics>
          <damping>0.01</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="base_front_caster_joint" type="ball">
      <parent>base_link</parent>
      <child>front_caster_link</child>
      <pose>0.16 0 -0.059 0 0 0</pose>
    </joint>

    <joint name="base_rear_caster_joint" type="ball">
      <parent>base_link</parent>
      <child>rear_caster_link</child>
      <pose>-0.16 0 -0.059 0 0 0</pose>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
      <pose>0.1 0 0.1 0 0 0</pose>
    </joint>

    <joint name="base_camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <pose>0.2075 0 0 0 0 0</pose>
    </joint>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
      <pose>0 0 0.05 0 0 0</pose>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>base_left_wheel_joint</left_joint>
      <right_joint>base_right_wheel_joint</right_joint>
      <wheel_separation>0.300</wheel_separation>
      <wheel_radius>0.025</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
      <max_linear_acceleration>1.0</max_linear_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>base_left_wheel_joint</joint_name>
      <joint_name>base_right_wheel_joint</joint_name>
    </plugin>

  </model>
</sdf>